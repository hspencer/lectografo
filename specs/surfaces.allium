-- allium: 3
-- surfaces.allium

-- Scope: contratos de superficie del sistema. Define las fronteras entre
-- el sistema y sus actores (investigador y LLM) sin describir interfaz
-- grafica ni endpoints HTTP concretos.
--
-- Includes:
--   - Actor Investigador (humano) y actor LLM (servicio externo)
--   - Surface de validacion de decisiones
--   - Surface de visualizacion del grafo
--   - Surface de invocacion del LLM
--   - Contrato Codec para serializar grafos
--   - Contrato EvaluadorLLM para invocar proveedores

use "./transcripcion.allium" as transcripcion
use "./extraccion.allium" as extraccion
use "./validacion.allium" as validacion
use "./grafo.allium" as grafo
use "./extraccion-incremental.allium" as extraccionIncremental
use "./edicion-texto.allium" as edicion

------------------------------------------------------------
-- Actores
------------------------------------------------------------

external entity Persona {
    nombre: String
    email: String?
}

external entity ServicioLLM {
    proveedor: extraccion/ProveedorLLM
    endpoint: String
}

actor Investigador {
    identified_by: Persona where nombre != ""
}

actor LLM {
    identified_by: ServicioLLM where proveedor in {anthropic, openai, gemini, ollama}
}

------------------------------------------------------------
-- Contratos
------------------------------------------------------------

contract Codec {
    serializar: (g: grafo/Grafo) -> ByteArray
    deserializar: (bytes: ByteArray) -> grafo/Grafo

    @invariant Roundtrip
        -- deserializar(serializar(g)) recupera un grafo equivalente
        -- en todos los campos observables.

    @guidance
        -- El formato concreto es JSON-LD. El codec no debe perder
        -- anotaciones del investigador ni notas_usuario.
}

contract EvaluadorLLM {
    invocar: (prompt: String, transcripcion: transcripcion/Transcripcion, on_token: (Integer -> Void)?) -> String
    -- on_token: callback opcional invocado en cada token generado; permite progreso en tiempo real y cancelación.
    parsear_respuesta: (texto: String) -> (List<extraccion/ConceptoPropuesto>, List<extraccion/RelacionPropuesta>, List<extraccion/BucleDetectado>, List<extraccion/FlagMetalenguaje>)

    @invariant ParseoEsTotal
        -- parsear_respuesta nunca lanza excepcion: para input invalido
        -- retorna listas vacias y la falla se reporta por otro canal.

    @guidance
        -- Cada proveedor (anthropic, openai, gemini, ollama) implementa este
        -- contrato detras de la misma interfaz.
}

------------------------------------------------------------
-- Surface: panel de validacion del investigador
------------------------------------------------------------

surface PanelValidacion {
    facing investigador: Investigador
    context transcripcion: transcripcion/Transcripcion where estado in {extraida, validada}

    let pendientes = validacion/PuntoDecision where transcripcion = transcripcion and estado = pendiente
    let diferidas = validacion/PuntoDecision where transcripcion = transcripcion and estado = diferida
    let estancadas = pendientes where esta_estancada = true

    exposes:
        pendientes
        diferidas
        estancadas
        for d in pendientes:
            d.pregunta
            d.recomendacion_llm
            d.tipo
            d.conceptos_implicados
            d.relacion_implicada
            d.bucle_implicado
            d.flag_implicado

    provides:
        InvestigadorResuelve(decision, aceptada, nota)
            when decision in pendientes
        InvestigadorResuelve(decision, rechazada, nota)
            when decision in pendientes
        InvestigadorResuelve(decision, modificada, nota)
            when decision in pendientes
        InvestigadorResuelve(decision, diferida, nota)
            when decision in pendientes
        InvestigadorReanudaDecision(decision)
            when decision in diferidas
        InvestigadorAgregaNota(transcripcion, objeto, nota)

    @guarantee NingunaDecisionSeCierraAutomaticamente
        -- El sistema nunca resuelve una decision sin accion explicita
        -- del investigador. Los timeouts solo marcan decisiones como
        -- estancadas, no las cierran.

    @guarantee TrazabilidadDeDecisiones
        -- Toda decision resuelta queda con timestamp y nota; las
        -- decisiones rechazadas no se borran, persisten para el
        -- registro hermeneutico.

    timeout:
        DecisionEstancadaSeDestaca when pendientes.any(d => d.esta_estancada)
}

------------------------------------------------------------
-- Surface: mapa topológico (force-directed)
------------------------------------------------------------

-- NOTA: Esta surface fue la vista principal hasta que se comprobó que con
-- grafos de más de ~15 nodos las frases de relación (frase_completa) son
-- completamente ilegibles: los labels se superponen, los arcos se cruzan y
-- no existe punto de entrada natural para la lectura. El mapa se mantiene
-- como vista de TOPOLOGÍA (estructura global, densidad, bucles), no como
-- superficie de lectura semántica. La navegación léxica vive en
-- NavegadorDendrograma.

surface VisualizacionGrafo {
    facing investigador: Investigador
    context grafo: grafo/Grafo

    exposes:
        grafo.titulo
        grafo.version
        grafo.total_nodos
        grafo.total_relaciones
        grafo.densidad
        for n in grafo.nodos:
            n.label
            n.tipos
            n.descripcion_corta
            n.sinonimos_consolidados
            n.notas_usuario
        for r in grafo.relaciones:
            r.etiqueta
            r.frase_completa
            r.bidireccional
            r.matiz
            r.tipo
        for b in grafo.bucles:
            b.descripcion
            b.tipo
            b.nodos

    provides:
        InvestigadorAgregaNota(grafo.transcripcion, objeto, nota)
        InvestigadorEligeNodoComoRaiz(nodo)
            -- Pivota al NavegadorDendrograma centrado en este nodo.
            -- Única acción de lectura disponible desde el mapa.

    related:
        NavegadorDendrograma(grafo)
        PanelValidacion(grafo.transcripcion)

    contracts:
        demands Codec

    @guidance
        -- Usar como referencia topológica, no como herramienta de lectura.
        -- El investigador puede arrastrar nodos y hacer zoom, pero la
        -- legibilidad se degrada con densidad alta. Para leer el argumento
        -- del texto, redirigir a NavegadorDendrograma.
}

------------------------------------------------------------
-- Surface: navegador dendrograma — "el viñedo del texto"
------------------------------------------------------------

-- La superficie primaria de lectura semántica del grafo.
-- Invierte la jerarquía del mapa: la FRASE DE RELACIÓN (frase_completa) es
-- el elemento principal de cada rama; el nodo es el destino de esa frase.
-- Leer el árbol equivale a leer las proposiciones del texto en cadena:
--   "FUEGO —[todo es transformación de]→ LOGOS —[gobierna]→ COSMOS"
--
-- El investigador elige un nodo raíz y el árbol se bifurca desde ahí.
-- Los ciclos se muestran como referencias colapsadas; no se expanden para
-- evitar explosión combinatoria. La profundidad es configurable.

-- NodoEnContexto representa un nodo tal y como aparece en el recorrido:
-- con la frase que lo conecta a su padre, la dirección y su posición.
value NodoEnContexto {
    nodo: grafo/Nodo
    relacion_entrada: grafo/Relacion?      -- null solo para la raíz
    frase_entrada: String?                 -- relacion_entrada.frase_completa
                                           -- la "frase oculta" que se revela al navegar
    direccion_entrada: saliente | entrante | nula
                                           -- saliente: padre→este; entrante: este→padre
                                           -- Las relaciones bidireccionales se muestran
                                           -- una sola vez con indicador ↔ (relacion_entrada.bidireccional)
    profundidad: Integer                   -- 0 = raíz
    es_referencia_ciclica: Boolean         -- ya aparece como ancestro en esta rama → no expandir
                                           -- Un mismo nodo puede ser raíz en otra Perspectiva
    es_nodo_de_bucle: Boolean              -- pertenece a algún Bucle del grafo (semántico, no de traversal)
    expandido: Boolean                     -- el investigador abrió esta rama
}

-- Perspectiva representa un árbol independiente con su propia raíz y profundidad.
-- El investigador puede abrir múltiples perspectivas simultáneas del mismo grafo.
value Perspectiva {
    id: String
    raiz: grafo/Nodo
    profundidad: Integer        -- 1..6; ajustable con slider por perspectiva
    arbol: List<NodoEnContexto>
}

surface NavegadorDendrograma {
    facing investigador: Investigador
    context grafo: grafo/Grafo

    -- Múltiples perspectivas simultáneas; la primera se abre automáticamente
    -- desde el nodo con mayor out-degree.
    let perspectivas = PerspectvasActivas(grafo)     -- inicialmente una

    exposes:
        grafo.titulo
        for p in perspectivas:
            p.id
            p.raiz.label
            p.raiz.descripcion_corta
            p.profundidad
            -- El árbol completo de esta perspectiva
            for nec in p.arbol:
                nec.nodo.label
                nec.nodo.descripcion_corta
                nec.nodo.tipos
                nec.frase_entrada              -- proposición completa; el corazón del texto
                nec.relacion_entrada.tipo
                nec.relacion_entrada.bidireccional
                nec.direccion_entrada
                nec.profundidad
                nec.es_referencia_ciclica
                nec.es_nodo_de_bucle
                nec.expandido

    provides:
        InvestigadorAbrePerspectiva(grafo, nodo)
            -- Abre una nueva perspectiva centrada en nodo.
            -- Cualquier nodo visible en cualquier perspectiva puede ser raíz.
        InvestigadorCierraPerspectiva(perspectiva)
            when perspectivas.count > 1
            -- Se puede cerrar cualquier perspectiva salvo la última.
        InvestigadorAjustaProfundidad(perspectiva, nueva_profundidad)
            -- Slider 1–6 por perspectiva; recalcula el árbol inmediatamente.
        InvestigadorExpandeRama(nodo_en_contexto)
            when not nodo_en_contexto.es_referencia_ciclica
             and not nodo_en_contexto.expandido
        InvestigadorColapsaRama(nodo_en_contexto)
            when nodo_en_contexto.expandido
        InvestigadorAgregaNota(grafo.transcripcion, objeto, nota)

    related:
        VisualizacionGrafo(grafo)
            -- Vista de topología global; accesible desde toggle en la misma pestaña
        PanelValidacion(grafo.transcripcion)

    @guarantee FrasesSiempreLegibles
        -- Cada rama del árbol muestra frase_completa de la relación que la
        -- conecta con su nodo padre. La frase es siempre el elemento
        -- dominante, independientemente del número total de nodos del grafo.

    @guarantee CiclosNoProducenExplosion
        -- Un nodo que ya aparece como ancestro directo en la misma rama se
        -- representa como referencia colapsada. No se expande.
        -- Un nodo ya visitado en OTRA rama puede expandirse de nuevo.

    @guarantee DireccionYBidireccionalidadVisibles
        -- La dirección de cada relación (→ saliente, ← entrante, ↔ bidireccional)
        -- es visible como indicador tipográfico en cada rama.
        -- Una relación bidireccional aparece UNA SOLA VEZ; nunca se duplica.

    @guarantee BuclesSemanticosDistinguibles
        -- Los nodos que participan en un Bucle detectado por el LLM se
        -- muestran con color diferente al de nodos no-bucle, distinguiéndolos
        -- visualmente de los artefactos de traversal (es_referencia_ciclica).

    @guarantee PerspectividadSimultanea
        -- El investigador puede tener abiertas N perspectivas del mismo grafo.
        -- Cada perspectiva tiene su propia raíz, profundidad y estado de expansión.
        -- Las perspectivas no comparten estado entre sí.
}

------------------------------------------------------------
-- Surface: mapa conceptual en construcción
------------------------------------------------------------

surface VisualizacionGrafoEnConstruccion {
    -- Mapa conceptual que crece en tiempo real mientras el LLM procesa
    -- el texto frase a frase. El investigador es espectador puro.
    -- Al completarse la sesión, esta vista cede lugar a VisualizacionGrafo.
    facing investigador: Investigador
    context sesion: extraccionIncremental/SesionExtraccionIncremental where estado = activa

    -- Nodos y relaciones ya materializados hasta este momento
    let nodos_actuales = NodosParcialesDeSesion(sesion)
    let relaciones_actuales = RelacionesParcialesdeSesion(sesion)

    exposes:
        sesion.transcripcion.titulo
        sesion.porcentaje_avance
        sesion.frases_procesadas
        sesion.total_frases
        sesion.frase_en_curso
        -- Nodos del grafo en construcción
        for n in nodos_actuales:
            n.label
            n.tipo
            n.es_nuevo_en_sesion
            -- es_nuevo_en_sesion: false si el nodo ya existía en grafo_preexistente
        -- Relaciones del grafo en construcción
        for r in relaciones_actuales:
            r.etiqueta
            r.origen.label
            r.destino.label
            r.es_nueva_en_sesion

    provides:
        InvestigadorAbortaSesion(sesion)

    transitions:
        when sesion.estado = completada -> VisualizacionGrafo(sesion.grafo_resultante)

    @guarantee InvestigadorEsEspectador
        -- Esta surface no permite editar el grafo en construcción.
        -- La única acción disponible es abortar la sesión.
        -- Las propuestas de consolidación se acumulan en segundo plano
        -- sin interrumpir la visualización ni requerir atención inmediata.

    @guarantee NodosAparecenAlInstante
        -- Cada ResultadoParcial nuevo causa que los nodos y relaciones
        -- detectados en esa frase aparezcan en el mapa inmediatamente,
        -- sin esperar al fin de la sesión ni al siguiente lote.

    @guarantee NodosExistentesSeDistinguen
        -- Los conceptos reconocidos como equivalentes a nodos del
        -- grafo_preexistente se muestran diferenciados de los nodos
        -- nuevos, pero se destacan visualmente al recibir nueva evidencia.
}

------------------------------------------------------------
-- Surface: invocacion del LLM
------------------------------------------------------------

surface InvocacionLLM {
    facing servicio: LLM
    context ejecucion: extraccion/EjecucionExtraccion where estado = en_curso

    exposes:
        ejecucion.transcripcion.texto_crudo
        ejecucion.transcripcion.fragmentos
        ejecucion.prompt.plantilla
        ejecucion.transcripcion.idioma

    provides:
        ExtraccionLLMRetornaResultado(ejecucion, conceptos, relaciones, bucles, metalenguaje)
        ExtraccionLLMRetornaError(ejecucion, razon)

    contracts:
        demands EvaluadorLLM

    @guarantee SinFugaDeDatos
        -- La unica informacion que cruza esta surface hacia el servicio
        -- LLM es la transcripcion y el prompt. No se envian anotaciones
        -- previas del investigador ni grafos en curso.

    @guarantee RespuestaJSONValida
        -- La respuesta del LLM debe ser JSON parseable. Si no lo es,
        -- se emite ExtraccionLLMRetornaError con razon = "json_invalido".

    timeout:
        ExtraccionLLMTimeout when ejecucion.iniciada_en + 5.minutes <= now
}

------------------------------------------------------------
-- Reglas de timeout (deben tener guarda como dice la guidance global)
------------------------------------------------------------

rule MarcarDecisionEstancada {
    when: d: validacion/PuntoDecision.creada_en + config.plazo_decision_estancada <= now
    requires: d.estado = pendiente

    ensures: DecisionEstancadaSeDestaca(decision: d)

    @guidance
        -- Esta regla no cierra la decision. Solo emite un trigger que
        -- el panel usa para destacar visualmente la decision como
        -- estancada.
}

rule AbortarExtraccionPorTimeout {
    when: e: extraccion/EjecucionExtraccion.iniciada_en + 5.minutes <= now
    requires: e.estado = en_curso

    ensures: ExtraccionLLMRetornaError(ejecucion: e, razon: "timeout")
}

rule CancelarExtraccion {
    when: CancelarExtraccion(ejecucion)
    requires: ejecucion.estado = en_curso
    ensures:
        ejecucion.estado = fallida
        ejecucion.finalizada_en = now
        ejecucion.razon_falla = "cancelado_por_investigador"
        ejecucion.transcripcion.estado = normalizada
        -- La transcripción vuelve a estado normalizada: puede procesarse de nuevo.
}

------------------------------------------------------------
-- Surface: configuracion del proveedor LLM
------------------------------------------------------------

surface ConfiguracionProveedor {
    facing investigador: Investigador

    exposes:
        extraccion/ProveedorActivo where es_local = false: proveedor, modelo, api_key_presente
        extraccion/ProveedorActivo where es_local = true:  proveedor, modelo, endpoint

    provides:
        InvestigadorSeleccionaProveedor(proveedor, modelo, api_key?)
            when proveedor in {anthropic, openai, gemini}
        InvestigadorSeleccionaProveedorLocal(modelo, endpoint)
            when proveedor = ollama
        InvestigadorSeleccionaModeloOllama(modelo)
            when proveedor = ollama
            -- modelo: seleccionado de la lista devuelta por el endpoint de Ollama

    @guarantee ApiKeyNoSeExponeEnOtrasSuperficies
        -- La api_key de proveedores remotos nunca aparece en otras surfaces
        -- ni en la serializacion del grafo. Solo es visible en esta surface
        -- para su configuracion.
}

------------------------------------------------------------
-- Surface: editor de texto fuente
------------------------------------------------------------

surface EditorTexto {
    -- Permite al investigador leer y editar el texto_crudo de una Transcripcion
    -- en cualquier estado. El texto se muestra renderizado como HTML
    -- (interpretando la sintaxis Markdown/txt del texto_crudo).
    facing investigador: Investigador
    context transcripcion: transcripcion/Transcripcion

    exposes:
        transcripcion.titulo
        transcripcion.estado
        transcripcion.texto_crudo                       -- como fuente del renderizado HTML
        transcripcion.texto_desincronizado_desde        -- null o timestamp de la última edición divergente
        transcripcion.fragmentos_invalidos
        transcripcion.revisiones                        -- historial completo de revisiones
        for rev in transcripcion.revisiones:
            rev.fecha
            rev.nota_autor
            -- texto_anterior disponible bajo demanda (puede ser voluminoso)

    provides:
        InvestigadorEditaTexto(transcripcion, texto_nuevo, nota?)
            -- Siempre disponible, en cualquier estado.
        InvestigadorSolicitaReNormalizacion(transcripcion)
            when transcripcion.fragmentos_invalidos = true
        InvestigadorConsultaRevision(revision)
            -- Muestra el texto_anterior completo de una revisión concreta.

    @guarantee TextoSiempreEditable
        -- InvestigadorEditaTexto está disponible independientemente del
        -- estado de la transcripcion. No existe bloqueo por estado.

    @guarantee HistorialNoEsDestructivo
        -- Ninguna acción en esta surface elimina revisiones existentes.
        -- El historial sólo crece; nunca se trunca.

    @guarantee DesincronizacionVisible
        -- Si texto_desincronizado_desde != null, la surface lo señala
        -- visiblemente antes de que el investigador pueda lanzar
        -- una nueva extracción.

    related:
        PanelBiblioteca
            when transcripcion.fragmentos_invalidos = false
                and transcripcion.estado = normalizada
}

------------------------------------------------------------
-- Surface: panel de biblioteca (vista principal)
------------------------------------------------------------

surface PanelBiblioteca {
    -- Vista principal de la aplicación: lista de textos disponibles,
    -- estado de cada uno, y control del proceso de extracción.
    facing investigador: Investigador

    exposes:
        -- Textos ya extraídos
        for t in transcripcion/Transcripcion where estado != raw:
            t.titulo
            t.estado
            t.metadatos
        -- Extracciones en curso: progreso en tokens
        for e in extraccion/EjecucionExtraccion where estado = en_curso:
            e.transcripcion.titulo
            e.tokens_generados       -- contador en tiempo real vía on_token
            e.tokens_total_estimado  -- estimación previa al inicio
            e.porcentaje_avance      -- tokens_generados * 100 / tokens_total_estimado, cap 90%
            e.elapsed                -- segundos desde iniciada_en

    provides:
        InvestigadorSolicitaExtraccion(transcripcion, proveedor, prompt)
            when transcripcion.estado = normalizada
        CancelarExtraccion(ejecucion)
            when ejecucion.estado = en_curso
        InvestigadorEditaMetadatos(transcripcion, metadatos)
            -- Editar ficha bibliográfica; funciona antes y después de extraer

    @guarantee ProgresoEnTiempoReal
        -- El conteo de tokens se actualiza en cada token generado,
        -- sin esperar al fin de la extracción. El porcentaje nunca
        -- supera el 90% hasta que la extracción completa.

    @guarantee CancelacionResponsiva
        -- Tras CancelarExtraccion, el proceso se detiene en el próximo token
        -- generado (< 1 segundo de latencia). Los archivos parciales no quedan
        -- escritos: la extracción cancelada deja el texto en estado normalizada.
}

------------------------------------------------------------
-- Deferred
------------------------------------------------------------

deferred NodosParcialesDeSesion(sesion: extraccionIncremental/SesionExtraccionIncremental) -> List<grafo/Nodo>
    -- Proyecta los ResultadoParciales acumulados hasta ahora en nodos
    -- del grafo (aplicando el tesauro y la equivalencia con grafo_preexistente).
    -- Devuelve el estado actual del grafo en construcción.

deferred RelacionesParcialesdeSesion(sesion: extraccionIncremental/SesionExtraccionIncremental) -> List<grafo/Relacion>
    -- Proyecta las relaciones detectadas hasta ahora en el grafo en construcción.

------------------------------------------------------------
-- Deferred: NavegadorDendrograma
------------------------------------------------------------

deferred NodoRaizActiva(grafo: grafo/Grafo) -> grafo/Nodo
    -- Devuelve el nodo con mayor out-degree (suma de salientes + entrantes).
    -- En caso de empate, el primero en orden de creacion.

deferred PerspectvasActivas(grafo: grafo/Grafo) -> List<Perspectiva>
    -- Devuelve las perspectivas abiertas por el investigador en esta sesión.
    -- Estado en memoria; no persiste entre sesiones.
    -- Al abrir el grafo, contiene una única perspectiva desde NodoRaizActiva.

deferred ProyectarArbol(
    grafo: grafo/Grafo,
    raiz: grafo/Nodo,
    profundidad_max: Integer
) -> List<NodoEnContexto>
    -- Recorrido DFS desde raiz hasta profundidad_max.
    -- Incluye tanto relaciones SALIENTES (padre es origen) como ENTRANTES (padre es destino).
    -- Una relación bidireccional aparece UNA SOLA VEZ: como saliente desde el lado que
    -- inicia el recorrido, con relacion_entrada.bidireccional = true.
    -- Cycle detection es PATH-LOCAL: un nodo ya en la ruta de ancestros directos
    -- → es_referencia_ciclica = true y no se expande.
    -- Un mismo nodo puede expandirse en distintas ramas si no es ancestro directo en esa rama.
    -- es_nodo_de_bucle = true si el nodo aparece en algún Bucle del grafo.
    -- Orden de los hijos: primero salientes, luego entrantes; dentro de cada grupo,
    -- orden de creacion de la relacion.

config {
    profundidad_dendrograma: Integer = 3
    -- Profundidad inicial del árbol de expansión.
    -- 2 = solo vecinos directos (poco contexto).
    -- 3 = vecinos y sus vecinos (equilibrio recomendado).
    -- 4+ = potencialmente abrumador con grafos densos.
}

------------------------------------------------------------
-- Preguntas abiertas
------------------------------------------------------------

open question "El timeout de 5 minutos para la invocacion del LLM es razonable para transcripciones largas? Hacerlo proporcional al tamano del input?"

open question "La surface VisualizacionGrafo expone la densidad pero no expone la lista completa de bucles con sus tipos. Es informacion que el investigador quiere ver en el panel principal o solo bajo demanda?"

open question "VisualizacionGrafoEnConstruccion: ¿la frase actualmente en proceso se muestra en el mapa (p.ej. como tooltip o panel lateral con el texto fuente), o solo el mapa de nodos y relaciones?"

open question "¿Cuándo sesion.estado = abortada, la VisualizacionGrafoEnConstruccion cierra y muestra el grafo parcial hasta ese punto, o vuelve a PanelBiblioteca?"

-- DECISIÓN RESUELTA: NavegadorDendrograma incluye relaciones SALIENTES y ENTRANTES
-- desde cada nodo padre. Las salientes se listan primero; las entrantes después.

-- DECISIÓN RESUELTA: Las relaciones bidireccionales aparecen UNA SOLA VEZ con
-- el indicador ↔. No se duplican.

-- DECISIÓN RESUELTA: El investigador puede tener MÚLTIPLES perspectivas simultáneas.
-- Cada perspectiva es una columna independiente con su propia raíz y profundidad.
-- Se pueden abrir desde cualquier nodo visible. La última perspectiva no se puede cerrar.

-- DECISIÓN RESUELTA: Los nodos que pertenecen a un Bucle semántico detectado por el
-- LLM se muestran con color distinto (amber/warning). Los artefactos de traversal
-- (es_referencia_ciclica) se muestran colapsados con icono ↺. Son categorías distintas.

-- DECISIÓN RESUELTA: La profundidad se ajusta con un SLIDER EN TIEMPO REAL por
-- perspectiva (rango 1–6). El árbol se recalcula inmediatamente al mover el slider.

-- DECISIÓN RESUELTA: El investigador selecciona el modelo Ollama de una lista
-- consultada en tiempo real al endpoint /api/tags de Ollama. El panel de
-- configuración muestra los modelos instalados y guarda la selección en .env.

-- DECISIÓN RESUELTA: La visualización force-directed (VisualizacionGrafo) se
-- mantiene como vista de topología secundaria. La superficie de lectura primaria
-- pasa a ser NavegadorDendrograma, donde la frase_completa de cada relación es
-- el elemento dominante de cada rama del árbol.
