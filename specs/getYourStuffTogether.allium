-- allium: 3
-- getYourStuffTogether.allium

-- Scope: deteccion y resolucion de nodos desconectados en un grafo ya construido.
-- Un nodo desconectado es aquel que no pertenece a la componente conexa
-- principal (la mayor) del grafo. Esto incluye tanto nodos aislados de grado 0
-- como clusters completos de varios nodos que estan conectados entre si pero
-- no con la masa principal del grafo.
-- Esta funcion propone conexiones via LLM y las somete al investigador
-- para su seleccion y edicion antes de formalizarlas en el grafo.
--
-- El nombre "getYourStuffTogether" es el nombre canonico en el proyecto.
--
-- Includes:
--   - Deteccion de nodos fuera de la componente principal del grafo existente
--   - Invocacion del LLM con el grafo como contexto comprimido y las citas de los nodos desconectados
--   - Filtrado de las propuestas del LLM para conservar solo las que reducen el numero de componentes conexas
--   - Presentacion de propuestas editables pre-seleccionadas al investigador
--   - Materializacion de las conexiones aceptadas como Relacion en el grafo
--
-- Excludes:
--   - Creacion de nodos nuevos (solo relaciones entre nodos existentes)
--   - Versionado del grafo (se modifica en su lugar, sin bumping de version)
--   - Validacion de relaciones ya existentes (vive en validacion.allium)

use "./grafo.allium" as grafo
use "./extraccion.allium" as extraccion

------------------------------------------------------------
-- Tipos
------------------------------------------------------------

-- Una conexion que el LLM propone entre dos nodos del grafo,
-- donde al menos uno de los extremos estaba desconectado (fuera de la
-- componente principal) al iniciar la ejecucion de reconexion.
entity ConexionPropuesta {
    id: String
    ejecucion: EjecucionReconexion
    origen: grafo/Nodo
    destino: grafo/Nodo
    frase: String                          -- descripcion de la relacion, editable por el investigador
    tipo: extraccion/TipoRelacion
    confianza: Decimal                     -- 0.0 a 1.0

    al_menos_un_desconectado: desconectado_en(origen, ejecucion.grafo)
                           or desconectado_en(destino, ejecucion.grafo)
}

-- Estado de una propuesta dentro de la sesion de revision del investigador.
enum EstadoPropuesta {
    pendiente      -- llegó del LLM, pre-seleccionada, esperando revision
    aceptada       -- investigador confirmó
    rechazada      -- investigador desmarcó
}

entity PropuestaEnRevision {
    id: String
    sesion: SesionReconexion
    conexion: ConexionPropuesta
    frase_editada: String                  -- puede ser la original del LLM o una version editada
    seleccionada: Boolean                  -- true por defecto (pre-marcada)
    estado: EstadoPropuesta

    transitions estado {
        pendiente -> aceptada
        pendiente -> rechazada
        terminal: aceptada, rechazada
    }
}

------------------------------------------------------------
-- Sesion de revision
------------------------------------------------------------

-- Una SesionReconexion agrupa las propuestas del LLM para que el
-- investigador las revise y confirme en una sola interaccion.
entity SesionReconexion {
    id: String
    grafo: grafo/Grafo
    ejecucion: EjecucionReconexion
    iniciada_en: Timestamp
    completada_en: Timestamp?
    estado: en_revision | completada | cancelada

    propuestas: PropuestaEnRevision with sesion = this
    aceptadas: propuestas where estado = aceptada
    rechazadas: propuestas where estado = rechazada
    pendientes: propuestas where estado = pendiente

    transitions estado {
        en_revision -> completada
        en_revision -> cancelada
        terminal: completada, cancelada
    }
}

------------------------------------------------------------
-- Ejecucion LLM de reconexion
------------------------------------------------------------

entity EjecucionReconexion {
    id: String
    grafo: grafo/Grafo
    proveedor: extraccion/ProveedorActivo
    prompt: extraccion/Prompt
    iniciada_en: Timestamp
    finalizada_en: Timestamp?
    estado: en_curso | completada | fallida
    razon_falla: String? when estado = fallida

    nodos_desconectados: List<grafo/Nodo>   -- snapshot de los nodos fuera de la componente principal al momento de iniciar

    transitions estado {
        en_curso -> completada
        en_curso -> fallida
        terminal: completada, fallida
    }
}

------------------------------------------------------------
-- Visibilidad del boton
------------------------------------------------------------

-- El boton "getYourStuffTogether" (icono: anillo de nodos) es visible
-- en la interfaz del grafo unicamente cuando hay nodos desconectados,
-- es decir, cuando el grafo tiene mas de una componente conexa.
-- Desaparece cuando el grafo queda completamente conexo.

rule BotonReconexionVisible {
    when: InvestigadorVisualizaGrafo(g)

    ensures:
        if nodos_desconectados(g).count > 0
        then AccionGetYourStuffTogetherDisponible(grafo: g)
        else AccionGetYourStuffTogetherOculta(grafo: g)
}

------------------------------------------------------------
-- Inicio de reconexion
------------------------------------------------------------

rule IniciarReconexion {
    when: InvestigadorActivaGetYourStuffTogether(g)

    requires: nodos_desconectados(g).count > 0
    requires: proveedor_activo.api_key_presente = true or proveedor_activo.es_local = true
    requires: proveedor_activo.es_local = false or proveedor_activo.endpoint != null

    let desconectados = nodos_desconectados(g)

    ensures: EjecucionReconexion.created(
        grafo: g,
        proveedor: proveedor_activo,
        prompt: prompt_reconexion(),        -- black box: carga el prompt especifico de reconexion
        iniciada_en: now,
        estado: en_curso,
        nodos_desconectados: desconectados
    )

    @guidance
        -- El LLM recibe:
        --   (a) el grafo existente serializado como contexto comprimido
        --       (nodos con label + descripcion, relaciones con etiqueta);
        --   (b) las citas directas de los nodos desconectados;
        --   (c) la transcripcion completa si su longitud cabe en el limite del prompt,
        --       omitida en caso contrario.
        -- El grafo ya es la compresion semantica del texto original; la transcripcion
        -- completa es un enriquecimiento opcional, no el contexto primario.
        -- El LLM puede proponer conexiones entre un nodo desconectado y un nodo de la
        -- componente principal, y tambien entre dos nodos desconectados entre si.
        -- ver src/pipeline/grafo.py::nodos_desconectados y
        --     src/app.py::iniciar_reconexion
}

------------------------------------------------------------
-- Retorno del LLM
------------------------------------------------------------

rule ReconexionLLMCompleta {
    when: ReconexionLLMRetornaResultado(ejecucion, conexiones_propuestas)

    requires: ejecucion.estado = en_curso

    -- Solo se conservan las conexiones que reducen el numero de componentes
    -- conexas: si ambos extremos ya estan en la misma componente, la conexion
    -- es redundante (una arista interna que no reconecta nada) y se descarta
    -- antes de que llegue al investigador. Ver la @guidance mas abajo.
    let conexiones_utiles = filtrar_conexiones_que_reducen_componentes(
        ejecucion.grafo, conexiones_propuestas
    )

    ensures:
        ejecucion.estado = completada
        ejecucion.finalizada_en = now
        let sesion = SesionReconexion.created(
            id: "rec_" + ejecucion.id,
            grafo: ejecucion.grafo,
            ejecucion: ejecucion,
            iniciada_en: now,
            estado: en_revision
        )
        for cp in conexiones_utiles:
            let conexion = ConexionPropuesta.created(
                id: "cp_" + cp.id,
                ejecucion: ejecucion,
                origen: cp.origen,
                destino: cp.destino,
                frase: cp.frase,
                tipo: cp.tipo,
                confianza: cp.confianza
            )
            PropuestaEnRevision.created(
                id: "pr_" + cp.id,
                sesion: sesion,
                conexion: conexion,
                frase_editada: cp.frase,    -- pre-cargada con la frase del LLM
                seleccionada: true,          -- todas pre-marcadas por defecto
                estado: pendiente
            )
        SesionReconexionLista(sesion: sesion)

    @guidance
        -- Filtrado por reduccion de componentes (filtrar_conexiones_que_reducen_componentes):
        -- una propuesta del LLM solo es util si sus dos extremos pertenecen a
        -- componentes conexas distintas en el momento de aplicarla; unirlos reduce
        -- en uno el numero de componentes del grafo. Si ambos extremos ya estan en
        -- la misma componente, aceptar la conexion solo agregaria una arista interna
        -- redundante mientras los clusters realmente aislados siguen aislados: se
        -- descarta y nunca se muestra al investigador.
        -- El filtrado es un proceso ordenado y con estado (no un predicado estatico):
        --   1. Se construye Union-Find sobre las componentes actuales del grafo.
        --   2. Se recorren las propuestas en orden de confianza descendente.
        --   3. Se conserva una propuesta solo si en ese punto sus extremos estan en
        --      componentes distintas; al conservarla se fusionan (union) esas dos
        --      componentes, de modo que las siguientes se evaluan contra el estado ya
        --      actualizado. Cuando varias propuestas compiten por unir el mismo par de
        --      componentes, sobrevive la de mayor confianza.
        -- Este orden greedy produce exactamente el conjunto de conexiones necesario
        -- para minimizar el numero de componentes, sin redundancias.
        -- Conectar dos nodos desconectados entre si (sin tocar la componente principal)
        -- SI se conserva cuando es el mejor puente disponible: reduce el total de
        -- componentes en uno, aunque el subgrafo resultante siga separado de la masa
        -- principal (ver la pregunta abierta resuelta al respecto).
        -- ver src/pipeline/reconexion.py::filtrar_conexiones_que_reducen_componentes
        --
        -- Tras el filtrado, el investigador ve una lista de frases editables con
        -- checkboxes, todas marcadas por defecto. Puede:
        --   - desmarcar las propuestas que no quiere aceptar,
        --   - editar el texto de las que decide conservar,
        --   - confirmar la seleccion completa de una vez.
}

rule ReconexionLLMFallida {
    when: ReconexionLLMRetornaError(ejecucion, razon)

    requires: ejecucion.estado = en_curso

    ensures:
        ejecucion.estado = fallida
        ejecucion.finalizada_en = now
        ejecucion.razon_falla = razon
        ReconexionAbortada(grafo: ejecucion.grafo, razon: razon)

    @guidance
        -- Un fallo no modifica el grafo. El boton sigue visible si quedan
        -- nodos desconectados y el investigador puede reintentar.
}

------------------------------------------------------------
-- Confirmacion del investigador
------------------------------------------------------------

rule InvestigadorConfirmaReconexion {
    when: InvestigadorEnviaSeleccion(sesion, items_aceptados)
    -- items_aceptados: List<{propuesta: PropuestaEnRevision, frase_final: String}>

    requires: sesion.estado = en_revision

    ensures:
        for item in sesion.propuestas:
            let aceptado = item in items_aceptados
            item.estado = if aceptado then aceptada else rechazada
            if aceptado:
                item.frase_editada = frase_final_de(item, items_aceptados)
        for item in sesion.aceptadas:
            grafo/Relacion.created(
                id: "rel_rec_" + item.id,
                grafo: sesion.grafo,
                origen: item.conexion.origen,
                destino: item.conexion.destino,
                tipo: item.conexion.tipo,
                etiqueta: item.frase_editada,
                frase_completa: item.frase_editada,
                bidireccional: false,
                notas_usuario: [],
                confianza_extraccion: item.conexion.confianza,
                estado_validacion: aceptada,
                creada_en: now
            )
        sesion.estado = completada
        sesion.completada_en = now
        ReconexionCompleta(
            grafo: sesion.grafo,
            conexiones_agregadas: sesion.aceptadas.count,
            nodos_desconectados_restantes: nodos_desconectados(sesion.grafo).count
        )

    @guidance
        -- Si tras la confirmacion quedan nodos desconectados (porque el investigador
        -- rechazo todas las propuestas para alguno de ellos, o el LLM no propuso una
        -- conexion util para reincorporar ese cluster a la componente principal), el
        -- boton vuelve a aparecer automaticamente segun la regla BotonReconexionVisible.
}

rule InvestigadorCancelaSesion {
    when: InvestigadorCancela(sesion)

    requires: sesion.estado = en_revision

    ensures:
        sesion.estado = cancelada
        -- El grafo no se modifica. El boton sigue visible si quedan nodos desconectados.
}

------------------------------------------------------------
-- Invariantes
------------------------------------------------------------

-- Toda ConexionPropuesta toca al menos un nodo que estaba desconectado
-- (fuera de la componente principal) al iniciar la ejecucion. Una conexion
-- entre dos nodos ambos dentro de la componente principal no reconecta nada.
invariant ConexionTieneAlMenosUnExtremoDesconectado {
    for cp in ConexionPropuesta:
        desconectado_en(cp.origen, cp.ejecucion.grafo)
        or desconectado_en(cp.destino, cp.ejecucion.grafo)
}

-- Ninguna ConexionPropuesta materializada une dos nodos que ya estaban en la
-- misma componente conexa: seria una arista redundante que no reduce el numero
-- de componentes del grafo. Esta es la parte estatica, comprobable en un unico
-- instante, de la regla de reduccion de componentes. La logica greedy ordenada
-- que la produce (Union-Find sobre confianza descendente) vive en el filtro
-- filtrar_conexiones_que_reducen_componentes; ver la @guidance de
-- ReconexionLLMCompleta y src/pipeline/reconexion.py.
invariant ConexionReduceComponentes {
    for cp in ConexionPropuesta:
        not mismo_componente(cp.origen, cp.destino, cp.ejecucion.grafo)
}

invariant PropuestaPerteneceASuEjecucion {
    for pr in PropuestaEnRevision:
        pr.conexion.ejecucion = pr.sesion.ejecucion
}

invariant ConfianzaEnRango {
    for cp in ConexionPropuesta:
        cp.confianza >= 0.0 and cp.confianza <= 1.0
}

------------------------------------------------------------
-- Preguntas abiertas
------------------------------------------------------------

open question "El LLM recibe las citas de TODOS los nodos desconectados en un solo prompt, o un prompt por nodo/cluster? Para grafos grandes con muchos nodos desconectados, un prompt unico puede superar el limite."

open question "Si el investigador cancela la sesion, se pueden recuperar las propuestas descartadas o se pierden definitivamente?"

-- RESUELTA: "Cuando dos nodos desconectados quedan conectados entre si pero no con
-- el resto del grafo, el boton vuelve a aparecer. Deberia el sistema advertir que el
-- subgrafo formado sigue siendo un componente aislado?"
--   Conectar dos nodos desconectados entre si esta explicitamente permitido por el
--   filtro filtrar_conexiones_que_reducen_componentes cuando es el mejor puente
--   disponible por confianza: reduce el total de componentes en uno, aunque el
--   subgrafo resultante siga separado de la componente principal. No se emite una
--   advertencia especial: el boton reaparece via BotonReconexionVisible mientras
--   nodos_desconectados(g).count > 0, que es la senal correcta y suficiente de que
--   el grafo aun no es conexo. El investigador puede volver a ejecutar la reconexion.

open question "El prompt de reconexion es el mismo que el de extraccion con contexto adicional, o es un prompt separado disenado especificamente para la tarea de reconexion?"

------------------------------------------------------------
-- Funciones deferred
------------------------------------------------------------

deferred nodos_desconectados(g: grafo/Grafo) -> List<grafo/Nodo>
    -- Devuelve todos los nodos que NO pertenecen a la componente conexa principal
    -- (la mayor) del grafo. Incluye tanto nodos aislados de grado 0 como clusters
    -- completos de varios nodos conectados entre si pero no con la masa principal.
    -- Se calcula sobre el grafo tratado como no dirigido.
    -- ver src/pipeline/grafo.py::nodos_desconectados
    --     (usa grafo/Grafo.componentes_conexas, ver src/models/grafo.py)

deferred desconectado_en(nodo: grafo/Nodo, g: grafo/Grafo) -> Boolean
    -- True si el nodo esta fuera de la componente conexa principal del grafo,
    -- es decir, si nodo pertenece a nodos_desconectados(g).

deferred mismo_componente(a: grafo/Nodo, b: grafo/Nodo, g: grafo/Grafo) -> Boolean
    -- True si los nodos a y b pertenecen a la misma componente conexa del grafo
    -- (tratado como no dirigido). Se apoya en grafo/Grafo.componentes_conexas.
    -- ver src/models/grafo.py::componentes_conexas / es_conexo

deferred filtrar_conexiones_que_reducen_componentes(
    g: grafo/Grafo, conexiones: List<ConexionPropuesta>
) -> List<ConexionPropuesta>
    -- Descarta las conexiones cuyos dos extremos ya estan en la misma componente
    -- conexa: aceptarlas no reduciria el numero de grafos inconexos, solo agregaria
    -- una arista interna redundante. Aplica Union-Find sobre las componentes actuales
    -- y recorre las conexiones en orden de confianza descendente, conservando solo las
    -- que en ese punto unen componentes distintas (cada una fusiona sus componentes,
    -- asi que las siguientes se evaluan contra el estado ya actualizado).
    -- ver src/pipeline/reconexion.py::filtrar_conexiones_que_reducen_componentes

deferred construir_contexto_grafo(g: grafo/Grafo) -> String
    -- Serializa el grafo como texto comprimido apto para un prompt LLM:
    -- nodos (label + descripcion_corta), relaciones (etiqueta), bucles (descripcion).

deferred prompt_reconexion() -> extraccion/Prompt
    -- Devuelve el prompt especifico de reconexion (archivo en prompts/).

deferred frase_final_de(item: PropuestaEnRevision, aceptados: List) -> String
    -- Extrae la frase editada por el investigador para un item aceptado.
