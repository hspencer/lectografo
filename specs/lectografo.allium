-- allium: 3
-- lectografo.allium — módulo raíz
--
-- Lectógrafo: herramienta de lectura y cartografía conceptual que transforma
-- textos en grafos de relaciones, conceptos y encuentros semánticos.
--
-- Lecto-: lectura, texto, lección, lo legible; el acto de interpretar un escrito.
-- -grafo: trazar, representar, registrar gráficamente; un instrumento que produce inscripción.
-- Juntos: "lo que grafica la lectura" — pasar del texto lineal a una topología de conceptos.
--
-- Scope: extraccion y refinamiento de grafos conceptuales desde transcripciones
-- de analisis filosoficos. El sistema toma texto, propone un grafo via LLM,
-- guia al investigador para validar puntos de decision, y persiste el resultado.
--
-- Includes:
--   - Ingesta de transcripciones (txt, md, VTT, salida de yt-dlp)
--   - Extraccion incremental frase a frase con tesauro y consolidacion
--   - Flujo de validacion humana de puntos de decision
--   - Persistencia y publicacion de grafos versionados
--   - Grafos personales: mapas libres del investigador con referencias vivas
--   - Visualizacion interactiva (contrato de superficie)
--   - Soporte de proveedores LLM remotos (anthropic, openai, gemini) y locales (ollama)
--
-- Excludes:
--   - Mecanismo de descarga de YouTube (se asume yt-dlp como black box)
--   - Transcripcion de audio (se asume Whisper o similar como black box)
--   - Autenticacion (el sistema es local, monousuario por instancia)
--   - Sincronizacion en la nube (todo es local y soberano)
--
-- Modulos:
--   transcripcion.allium          -> ciclo de vida del texto de entrada
--   extraccion.allium             -> tipos base del LLM (vocabulario compartido)
--   extraccion-incremental.allium -> extraccion frase a frase con tesauro
--   validacion.allium             -> resolucion humana de ambiguedades
--   grafo.allium                  -> estructura persistente y publicacion
--   grafos-personales.allium      -> mapas libres del investigador
--   surfaces.allium               -> contratos de UI e integracion LLM

use "./transcripcion.allium" as transcripcion
use "./extraccion.allium" as extraccion
use "./extraccion-incremental.allium" as incremental
use "./validacion.allium" as validacion
use "./grafo.allium" as grafo
use "./grafos-personales.allium" as personal
use "./surfaces.allium" as surfaces

------------------------------------------------------------
-- Configuracion del modulo
------------------------------------------------------------

config {
    -- Tamano maximo de transcripcion procesada en un solo prompt (extraccion rapida).
    -- Transcripciones mayores deben fragmentarse antes de la extraccion rapida,
    -- o usar la extraccion incremental que procesa frase a frase sin limite.
    max_chars_por_prompt: Integer = 40000

    -- Umbral de confianza bajo el cual una triplet extraida pasa a estado
    -- dudosa y requiere atencion explicita del investigador.
    confianza_minima: Decimal = 0.6

    -- Numero minimo de menciones para considerar dos terminos como
    -- candidatos a sinonimo automaticamente.
    menciones_minimas_para_sinonimia: Integer = 2

    -- Plazo desde que un punto de decision queda pendiente hasta que el
    -- sistema lo destaca como "estancado" en el panel de validacion.
    plazo_decision_estancada: Duration = 7.days

    -- Plazo maximo que el sistema espera al servicio LLM antes de abortar.
    timeout_llm: Duration = 5.minutes
}

------------------------------------------------------------
-- Invariantes globales
------------------------------------------------------------

-- DECISIÓN RESUELTA: Los grafos no tienen estados; siempre están en edición.
-- El invariant GrafoPublicadoEsInmutable fue eliminado (ver grafo.allium).

invariant TodaRelacionTieneNodosExistentes {
    for r in grafo/Relacion:
        exists r.origen and exists r.destino
}

invariant NoHayDecisionesSinPropuesta {
    for d in validacion/PuntoDecision:
        d.recomendacion_llm != null
}

invariant LinajeNodoTrazable {
    for n in grafo/Nodo:
        n.grafo.transcripcion != null
    -- Todo Nodo de un GrafoDerivado es trazable a su transcripcion fuente.
}

invariant ReferenciaPersonalViva {
    for ref in personal/ReferenciaConcepto:
        (ref.nodo_derivado = null) != (ref.concepto_investigador = null)
    -- Una referencia siempre apunta exactamente a una fuente.
}

------------------------------------------------------------
-- Preguntas abiertas del modulo
------------------------------------------------------------

open question "Cuando el investigador rechaza una propuesta de sinonimia, ¿los nodos quedan separados para siempre o pueden volver a fusionarse en una versión posterior del grafo?"

open question "Si dos grafos publicados sobre la misma transcripcion difieren, ¿hay mecanismo de comparacion explicito o se tratan como obras independientes?"

open question "Un bucle de retroalimentacion detectado por el LLM y rechazado por el investigador: ¿queda registrado como decision negativa para que el LLM no lo vuelva a proponer, o se descarta sin huella?"

open question "Re-extraccion: cuando un Nodo de un GrafoDerivado desaparece tras re-extraer el texto (el LLM ya no lo detecta), ¿las ReferenciaConcepto de grafos personales que apuntaban a ese Nodo se convierten en referencias huerfanas o se eliminan en cascada?"

@guidance
    -- El investigador es la autoridad final en cualquier interpretacion.
    -- El LLM solo propone; nunca cierra una decision por timeout o por
    -- defecto. Una decision sin resolver bloquea la publicacion del grafo.
    --
    -- Los grafos personales son la capa de sintesis del investigador:
    -- ahi los textos se cruzan, los conceptos se conectan y el pensamiento
    -- propio del investigador toma forma junto al corpus.
