# Llull - configuracion local
# Copia este archivo a .env y edita los valores. Nunca commitear .env real.

# Proveedor LLM: anthropic | openai | gemini | ollama
# Sin default: debe elegirse explicitamente.
PROVIDER=

# Claves de cada proveedor remoto. Solo se requiere la del PROVIDER elegido.
# Para ollama no se usa API key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Modelo concreto por proveedor (opcional; el codigo trae defaults razonables).
ANTHROPIC_MODEL=
OPENAI_MODEL=
GEMINI_MODEL=

# Ollama: endpoint y modelo local.
# PROVIDER=ollama activa el modo local; no se requiere API key.
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=

# Carpeta de transcripciones de entrada (relativa al repo).
TRANSCRIPTS_DIR=transcripts

# Carpeta de grafos persistidos (relativa al repo).
GRAFOS_DIR=data/grafos

# Idioma por defecto de las transcripciones (codigo ISO 639-1).
LANG_DEFAULT=es

# Confianza minima de extraccion bajo la cual el LLM debe marcar la triplet como dudosa.
CONFIANZA_MINIMA_EXTRACCION=0.6
