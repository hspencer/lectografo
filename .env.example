# Lectógrafo — configuración local
# Copia este archivo a .env y edita los valores. Nunca commitear .env real.

# ─── Proveedor LLM activo ─────────────────────────────────────────────────────
# Opciones: anthropic | openai | gemini | ollama
# Sin default: debe elegirse explícitamente.
PROVIDER=ollama

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Default si no se especifica: claude-opus-4-6
ANTHROPIC_MODEL=claude-opus-4-6

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Default si no se especifica: gpt-4o
OPENAI_MODEL=gpt-4o

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Default si no se especifica: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# ─── Ollama (modo local, sin API key) ─────────────────────────────────────────
# Instalar Ollama en: https://ollama.com
# Descargar un modelo: ollama pull qwen2.5:7b
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── Paths ────────────────────────────────────────────────────────────────────
# Carpeta de transcripciones de entrada (relativa al repo).
TRANSCRIPTS_DIR=transcripts

# Carpeta de grafos persistidos (relativa al repo).
GRAFOS_DIR=data/grafos

# ─── Comportamiento ───────────────────────────────────────────────────────────
# Idioma por defecto de las transcripciones (código ISO 639-1).
LANG_DEFAULT=es

# Confianza mínima de extracción bajo la cual el LLM debe marcar la tripleta como dudosa.
CONFIANZA_MINIMA_EXTRACCION=0.6

# Máximo de caracteres del transcript enviados en un solo prompt.
# Textos más largos se procesan en modo incremental (por lotes).
# Para modelos con contexto grande (ej. qwen2.5 128K) se puede subir a 120000.
MAX_CHARS_PROMPT=40000
