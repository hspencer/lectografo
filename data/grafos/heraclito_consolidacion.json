        ],
        "label_canonico": "Pensar esencial",
        "justificacion": "Ambos nodos describen el mismo modo de pensar: lento, cuidadoso, meditativo, diferente del pensar calculador. c_076 enfatiza la ley de lentitud; c_083 destaca la meditación. Son manifestaciones del mismo concepto.",
        "confianza": 0.96
      },
      "label_editado": "Pensar esencial",
      "seleccionada": true,
      "estado": "pendiente"
    },
    {
