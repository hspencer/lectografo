        ],
        "label_canonico": "Categorías (κατηγορία)",
        "justificacion": "Ambos nodos tratan el mismo concepto: las determinaciones universales del ente que se muestran en su apariencia. c_248 añade la etimología griega (enunciado público) pero ambos hablan de lo mismo.",
        "confianza": 0.98
      },
      "label_editado": "Categorías (κατηγορία)",
      "seleccionada": true,
