        ],
        "label_canonico": "Zoón (ζῷον)",
        "justificacion": "Ambos nodos definen el mismo término griego zoón (aquello que surge y aparece, ser viviente). c_089 enfatiza el significado originario para los dioses; c_275 subraya la vida como determinante del ser.",
        "confianza": 0.95
      },
      "label_editado": "Zoón (ζῷον)",
      "seleccionada": true,
